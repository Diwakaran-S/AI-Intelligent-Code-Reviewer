# ──────────────────────────────────────────────────────────
#  Intelligent Code Reviewer & Explainer — Environment
# ──────────────────────────────────────────────────────────

# NVIDIA NIM API (OpenAI-compatible endpoint)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model — use the full namespace identifier
# Options: meta/llama-3.3-70b-instruct | meta/llama-3.1-8b-instruct
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# LLM Parameters
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=300
LLM_TEMPERATURE=0.1
